# ---------------------------------------------------------------------------
# Ecclesia Vote — example environment. Copy to .env.local and fill in.
# NEVER commit a real .env. CI runs gitleaks to enforce this (WP-00 / §9.2).
# ---------------------------------------------------------------------------

# Supabase (local dev defaults are printed by `supabase start`)
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_ANON_KEY="replace-with-local-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-local-service-role-key"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Next.js public vars (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-local-anon-key"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare Turnstile — public endpoints ONLY, never the ballot cast step (§0.4, §9.1)
TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# Database roles used by the application zones (§3.3). Passwords are local-only.
APP_IDENTITY_DB_PASSWORD="local-identity-pw"
APP_BALLOTBOX_DB_PASSWORD="local-ballotbox-pw"
APP_CREDAUTH_DB_PASSWORD="local-credauth-pw"
